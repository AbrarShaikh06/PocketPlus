{
  "name": "pocketplus-firestore-rules-tests",
  "private": true,
  "description": "Security rules tests for PocketPlus. Run against the Firestore emulator.",
  "scripts": {
    "test": "mocha test/firestore.rules.test.js --timeout 20000 --exit",
    "test:emulator": "firebase emulators:exec --only firestore --project demo-pocketplus \"npm test\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "firebase": "^12.9.0",
    "firebase-tools": "^13.35.1",
    "mocha": "^11.0.0"
  }
}
